# OGCS CRM Backend - Environment Configuration
# Copy this to .env.development and .env.production and fill in your values

# ============================================
# Application Environment
# ============================================
NODE_ENV=development
PORT=3181

# ============================================
# Database Configuration
# ============================================
# Development MongoDB
MONGO_URI_DEV=mongodb://localhost:27017/ogcs-crm-dev

# Production MongoDB (Atlas or other)
MONGO_URI_PROD=mongodb+srv://username:password@cluster.mongodb.net/ogcs-crm-prod

# ============================================
# Client URLs (CORS Configuration)
# ============================================
CLIENT_URL_DEV=http://localhost:5173
CLIENT_URL_PROD=https://crm.ogcs.co.in
CLIENT_URL=http://localhost:5173

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=your-very-secure-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ============================================
# Email Configuration (Nodemailer)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@ogcs.co.in

# ============================================
# Redis Cache (Optional but recommended)
# ============================================
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password (if needed)

# ============================================
# File Upload Configuration
# ============================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  # 10 MB in bytes
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.jpg,.jpeg,.png,.xlsx,.csv

# ============================================
# API Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ============================================
# Logging
# ============================================
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=combined  # combined, short, dev

# ============================================
# Application URLs
# ============================================
SERVER_URL=http://localhost:3181
API_BASE_URL=/api

# ============================================
# Third-party Services (Optional)
# ============================================
# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Sentry (Error tracking)
SENTRY_DSN=

# ============================================
# Security
# ============================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,https://crm.ogcs.co.in

# Security headers
HELMET_CSP_ENABLED=true

# ============================================
# Database
# ============================================
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=5000
